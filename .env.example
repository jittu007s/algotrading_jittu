# Copy this file to .env and fill in your real values. Never commit .env.

ANGEL_API_KEY=your_smartapi_api_key
ANGEL_CLIENT_CODE=your_angel_one_client_code
ANGEL_MPIN=your_angel_one_mpin
ANGEL_TOTP_SECRET=your_totp_base32_secret

# true = log signals only, no real orders sent. Keep true until validated.
DRY_RUN=true
